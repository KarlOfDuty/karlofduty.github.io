@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="row mb-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body d-flex align-items-center">
                <img src="img/tardisGifSmall.gif" alt="Tardis avatar" class="rounded-circle me-3" style="width: 64px; height: 64px;">
                <div>
                    <h5 class="card-title mb-0">KarlofDuty</h5>
                    <p class="text-muted small mb-0">Programmer & Server Host</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-8">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h4 class="card-title">About</h4>
                <p class="card-text">
                    I make Discord bots and other small projects on Github, and run some game servers.
                </p>
                <div class="d-grid gap-2 d-md-block">
                    <a href="https://discord.gg/C5qMvkj" class="btn btn-primary" target="_blank">Join Discord</a>
                    <a href="https://github.com/sponsors/KarlOfDuty" class="btn btn-outline-success" target="_blank">Sponsor on GitHub</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Contact</h5>

            </div>
        </div>
    </div>
</div>

<h3 class="mb-3 mt-7">Featured Projects</h3>
<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Gmod Store Projects</h5>
                <p class="card-text small">Various scripts and tools for Garry's Mod servers.</p>
                <a href="https://github.com/KarlOfDuty" class="btn btn-sm btn-outline-primary" target="_blank">View on GitHub</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Server Software</h5>
                <p class="card-text small">Custom built software for game server management and automation.</p>
                <a href="https://github.com/KarlOfDuty" class="btn btn-sm btn-outline-primary" target="_blank">View on GitHub</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Game Mods</h5>
                <p class="card-text small">Modifications for various games including SCP, Minecraft, and more.</p>
                <a href="https://github.com/KarlOfDuty" class="btn btn-sm btn-outline-primary" target="_blank">View on GitHub</a>
            </div>
        </div>
    </div>
</div>
